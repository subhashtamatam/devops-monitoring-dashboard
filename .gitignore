.env

# ── Generated Alertmanager config (contains real SMTP password) ──
alertmanager.yml

# ── Persistent alert history database (runtime data, not source) ──
alerts.db

# ── Dashboard login — user accounts and rate-limiting data ──
# users.json contains password hashes; login_security.db tracks failed
# login attempts. Neither should ever be committed.
users.json
login_security.db

# ── Python cache files ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Pytest cache ──
.pytest_cache/
.cache/
*.egg-info/

# ── Virtual environment ──
venv/
env/
.venv/

# ── Prometheus data directory (time-series storage) ──
data/
prometheus_data/

# ── Grafana local data ──
grafana_data/

# ── Nginx logs ──
*.log

# ── OS files ──
.DS_Store
Thumbs.db

#── Prometheus & Alertmanager binaries (never commit) ──
prometheus/
alertmanager/
alertmanager-*.tar.gz
*.tar.gz
*.pid
logs/*.pid
