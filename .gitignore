# DevOps Monitoring Dashboard — .gitignore
# Real-Time Application Performance Monitoring Dashboard
# PG Final Year Major Project

# ── Environment variables (NEVER commit .env — contains passwords) ──
.env

# ── Python cache files ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Pytest cache ──
.pytest_cache/
.cache/
*.egg-info/

# ── Virtual environment ──
venv/
env/
.venv/

# ── Prometheus data directory (time-series storage) ──
data/
prometheus_data/

# ── Grafana local data ──
grafana_data/

# ── Nginx logs ──
*.log

# ── OS files ──
.DS_Store
Thumbs.db
